@ECHO OFF
REM =============================================================
REM DOS HEALTHCHECK / SYSTEM AUDIT
REM Compatible target: MS-DOS 3.x, 4.x, 5.x and 6.x
REM Output file: DOS-REPORT.TXT
REM =============================================================

CLS
ECHO ===============================================
ECHO        DOS HEALTHCHECK / SYSTEM AUDIT
ECHO ===============================================
ECHO.
ECHO This tool creates DOS-REPORT.TXT using classic DOS commands.
ECHO It does not change system configuration.
ECHO.

IF EXIST DOS-REPORT.TXT DEL DOS-REPORT.TXT

ECHO DOS HEALTHCHECK / SYSTEM AUDIT > DOS-REPORT.TXT
ECHO Compatible with MS-DOS 3.x, 4.x, 5.x and 6.x >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [DOS VERSION] >> DOS-REPORT.TXT
VER >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [CURRENT DRIVE AND DIRECTORY] >> DOS-REPORT.TXT
CD >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [PATH] >> DOS-REPORT.TXT
PATH >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [ROOT DIRECTORY LISTING] >> DOS-REPORT.TXT
DIR C:\ >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [CONFIG.SYS] >> DOS-REPORT.TXT
IF EXIST C:\CONFIG.SYS TYPE C:\CONFIG.SYS >> DOS-REPORT.TXT
IF NOT EXIST C:\CONFIG.SYS ECHO C:\CONFIG.SYS not found. >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [AUTOEXEC.BAT] >> DOS-REPORT.TXT
IF EXIST C:\AUTOEXEC.BAT TYPE C:\AUTOEXEC.BAT >> DOS-REPORT.TXT
IF NOT EXIST C:\AUTOEXEC.BAT ECHO C:\AUTOEXEC.BAT not found. >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [MEMORY CHECK] >> DOS-REPORT.TXT
ECHO MEM command availability depends on DOS version. >> DOS-REPORT.TXT
MEM >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [CHKDSK SUMMARY] >> DOS-REPORT.TXT
ECHO CHKDSK output may vary between DOS versions. >> DOS-REPORT.TXT
CHKDSK C: >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [COMMON DOS FILES] >> DOS-REPORT.TXT
IF EXIST C:\DOS\HIMEM.SYS ECHO Found: C:\DOS\HIMEM.SYS >> DOS-REPORT.TXT
IF EXIST C:\DOS\EMM386.EXE ECHO Found: C:\DOS\EMM386.EXE >> DOS-REPORT.TXT
IF EXIST C:\DOS\SMARTDRV.EXE ECHO Found: C:\DOS\SMARTDRV.EXE >> DOS-REPORT.TXT
IF EXIST C:\DOS\MSCDEX.EXE ECHO Found: C:\DOS\MSCDEX.EXE >> DOS-REPORT.TXT
IF EXIST C:\DOS\DOSKEY.COM ECHO Found: C:\DOS\DOSKEY.COM >> DOS-REPORT.TXT
IF EXIST C:\DOS\QBASIC.EXE ECHO Found: C:\DOS\QBASIC.EXE >> DOS-REPORT.TXT
IF EXIST C:\DOS\EDIT.COM ECHO Found: C:\DOS\EDIT.COM >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO [NOTES] >> DOS-REPORT.TXT
ECHO Review CONFIG.SYS and AUTOEXEC.BAT for device drivers and TSR programs. >> DOS-REPORT.TXT
ECHO On DOS 5.x and 6.x, MEM /C may provide more detailed memory usage. >> DOS-REPORT.TXT
ECHO On DOS 6.x, MEMMAKER may help optimize conventional memory. >> DOS-REPORT.TXT
ECHO On DOS 3.x and 4.x, memory management features are more limited. >> DOS-REPORT.TXT
ECHO. >> DOS-REPORT.TXT

ECHO Report created: DOS-REPORT.TXT
ECHO.
ECHO Done.
