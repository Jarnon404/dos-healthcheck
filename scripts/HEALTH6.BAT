@ECHO OFF
REM =============================================================
REM DOS HEALTHCHECK EXTENDED FOR MS-DOS 6.x
REM Uses commands/options typically available in DOS 6.x.
REM Output file: DOS6-REPORT.TXT
REM =============================================================

CLS
ECHO ===============================================
ECHO        DOS 6.x EXTENDED HEALTHCHECK
ECHO ===============================================
ECHO.

IF EXIST DOS6-REPORT.TXT DEL DOS6-REPORT.TXT

ECHO DOS 6.x EXTENDED HEALTHCHECK > DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO [DOS VERSION] >> DOS6-REPORT.TXT
VER >> DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO [MEMORY DETAIL] >> DOS6-REPORT.TXT
MEM /C >> DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO [MEMORY DEBUG DETAIL] >> DOS6-REPORT.TXT
MEM /D >> DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO [CONFIG.SYS] >> DOS6-REPORT.TXT
IF EXIST C:\CONFIG.SYS TYPE C:\CONFIG.SYS >> DOS6-REPORT.TXT
IF NOT EXIST C:\CONFIG.SYS ECHO C:\CONFIG.SYS not found. >> DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO [AUTOEXEC.BAT] >> DOS6-REPORT.TXT
IF EXIST C:\AUTOEXEC.BAT TYPE C:\AUTOEXEC.BAT >> DOS6-REPORT.TXT
IF NOT EXIST C:\AUTOEXEC.BAT ECHO C:\AUTOEXEC.BAT not found. >> DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO [DISK CHECK] >> DOS6-REPORT.TXT
CHKDSK C: >> DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO [DOS 6.x TOOLS CHECK] >> DOS6-REPORT.TXT
IF EXIST C:\DOS\MEMMAKER.EXE ECHO Found: C:\DOS\MEMMAKER.EXE >> DOS6-REPORT.TXT
IF EXIST C:\DOS\SCANDISK.EXE ECHO Found: C:\DOS\SCANDISK.EXE >> DOS6-REPORT.TXT
IF EXIST C:\DOS\DEFRAG.EXE ECHO Found: C:\DOS\DEFRAG.EXE >> DOS6-REPORT.TXT
IF EXIST C:\DOS\MSBACKUP.EXE ECHO Found: C:\DOS\MSBACKUP.EXE >> DOS6-REPORT.TXT
IF EXIST C:\DOS\SMARTDRV.EXE ECHO Found: C:\DOS\SMARTDRV.EXE >> DOS6-REPORT.TXT
ECHO. >> DOS6-REPORT.TXT

ECHO Report created: DOS6-REPORT.TXT
ECHO Done.
